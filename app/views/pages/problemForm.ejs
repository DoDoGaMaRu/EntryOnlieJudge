<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='https://codersit.co.kr/coders/mission/bootstrap/css/bootstrap.css' />
    <script src="https://codersit.co.kr/coders/mission/jquery/jquery-3.4.1.min.js"></script>
    <script src="https://codersit.co.kr/coders/mission/bootstrap/js/popper.min.js"></script>
    <script src="https://codersit.co.kr/coders/mission/bootstrap/js/bootstrap.js"></script>
    <script src="https://codersit.co.kr/coders/confetti_v2.js"></script>
    <script type="module" src="/js/problemForm.js"></script>
    <style>
      html, body { height: 100%; overflow: hidden;}
      .svg-button { cursor: pointer; transition: fill 0.2s; margin: 0 0.3rem; }
      .svg-button:hover { fill: #999999; }
      .indicator { margin: 0 0.4rem; }
      .indicator-selected { fill: #FAFAFA; }
      .no-drag { user-select: none; }
      #btnSubmit { height: 1.5rem; font-size: 0.8rem; font-weight: 600; color: #555555; border: none; border-radius: 1rem; background-color: #FEFEFE; transition: background-color color 0.2s;}
      #btnSubmit:hover {background-color: #29c45c; color: #FEFEFE;}
    </style>
  </head>
  <body>
    <div class="d-flex flex-row h-100 w-100">
      <div id="left" class="d-flex flex-column" style="min-width: 1024px; width: 65%">
        
        <div class="top-nav d-flex flex-row justify-content-between align-items-center" style="height: 2rem; padding: 0.3rem 0; background-color: #4f80ff;">  
          <div class="top-nav-left w-25 d-flex flex-row justify-content-between" style="padding: 0 0.3rem;">
            <svg id="btnPrev" class='svg-button' xmlns="http://www.w3.org/2000/svg" enable-background="new 0 0 24 24" height="1.5rem" viewBox="0 0 24 24" width="1.5rem" fill="#FEFEFE"><g><rect fill="none" height="24" width="24"/></g><g><path d="M2,12c0,5.52,4.48,10,10,10s10-4.48,10-10c0-5.52-4.48-10-10-10C6.48,2,2,6.48,2,12z M12,11l4,0v2l-4,0l0,3l-4-4l4-4L12,11 z"/></g></svg>
          </div>
          <div class="top-nav-mid w-50 d-flex flex-column align-items-center h-100">
            <div class="nav-title h-75 d-flex flex-column justify-content-center pb-1">
              <span id="navTitle" class="no-drag" style="font-size: 0.9rem; color: #FFFFFF; font-weight: 600;"></span>
            </div>
            <div class="nav-indicator h-25 d-flex flex-row justify-content-between"></div>
          </div>
          <div class="top-nav-right w-25 d-flex flex-row justify-content-end" style="padding: 0 0.3rem;">
            <div class="util-box d-flex flex-row">


              <div id="loadEnt" class="d-none">
                <input id="fileInput" class="d-none" type="file" name="file" accept=".ent"/>
                <svg id='btnLoadEnt' class='svg-button' xmlns="http://www.w3.org/2000/svg" enable-background="new 0 0 24 24" height="1.5rem" viewBox="0 0 24 24" width="1.5rem" fill="#FEFEFE"><g><rect fill="none" height="24" width="24"/><path d="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2.01,6L2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M14,16H6v-2h8V16z M18,12H6v-2h12V12z"/></g></svg>
              </div>

              <div id="resetEnt" class="d-none">
                <svg id="btnResetEnt" class='svg-button' xmlns="http://www.w3.org/2000/svg" height="1.5rem" viewBox="0 0 24 24" width="1.5rem" fill="#FEFEFE"><path d="M0 0h24v24H0z" fill="none"/><path d="M0 0h24v24H0V0z" fill="none"/><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm2.46-7.12l1.41-1.41L12 12.59l2.12-2.12 1.41 1.41L13.41 14l2.12 2.12-1.41 1.41L12 15.41l-2.12 2.12-1.41-1.41L10.59 14l-2.13-2.12zM15.5 4l-1-1h-5l-1 1H5v2h14V4z"/></svg>
              </div>

              <div id="rollbackEnt" class="d-none">
                <svg id='btnRollbackEnt' class='svg-button' xmlns="http://www.w3.org/2000/svg" height="1.5rem" viewBox="0 0 24 24" width="1.5rem" fill="#FEFEFE"><path d="M0 0h24v24H0z" fill="none"/><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
              </div>
              
            </div>

            <div style="border-right: 1px solid #FAFAFA; height: 1rem; margin: auto 0.5rem"></div>

            <button id="btnSubmit">Finish</button>

            <div style="border-right: 1px solid #FAFAFA; height: 1rem; margin: auto 0.5rem"></div>

            <svg id="btnNext" class='svg-button' xmlns="http://www.w3.org/2000/svg" enable-background="new 0 0 24 24" height="1.5rem" viewBox="0 0 24 24" width="1.5rem" fill="#FEFEFE"><g><rect fill="none" height="24" width="24"/></g><g><path d="M22,12c0-5.52-4.48-10-10-10S2,6.48,2,12c0,5.52,4.48,10,10,10S22,17.52,22,12z M12,13l-4,0v-2l4,0V8l4,4l-4,4V13z"/></g></svg>
          </div>
        </div>

        <div class="flex-grow-1 no-drag">
          <div id="infoEditor">

            <div style="height: 2.4rem; background-color: #4f80ff;"></div>

          </div>
          <iframe id="entry" src="/component/workspace" frameborder="0" class="h-100 w-100"></iframe>
        </div>
      </div>
      <div id="resizer" class="resizer h-100" style="background-color: #FAFAFA; border: #DDDDDD solid 1px; cursor: col-resize; min-width: 0.7%; max-width: 0.7%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="80%" height="100%" viewBox="0 0 24 24" fill="none">
          <rect x="6" y="5" width="4" height="30" rx="1" stroke="#222222" stroke-linecap="round"/>
          <rect x="14" y="5" width="4" height="30" rx="1" stroke="#222222" stroke-linecap="round"/>
          </svg>
      </div>
      <div id="right" class="d-flex flex-grow-1" style="background-color: #dddddd; overflow: hidden">
        <div class="h-100 w-100 no-drag">
          <iframe id="editor" src="/component/textEditor" frameborder="0" class="h-100 w-100"></iframe>
        </div>
      </div>
    </div>
  </body>
</html>
